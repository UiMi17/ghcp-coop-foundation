+    private static void FlushDeferredStateApplies(bool logState, bool logHealth)
+    {
+        float now = Time.time;
+        if (DeferredDamageByVictim.Count > 0)
+        {
+            foreach (KeyValuePair<uint, DeferredDamageState> kv in DeferredDamageByVictim.ToArray())
+            {
+                Unit? victim = CoopUnitLookup.TryFindByNetId(kv.Key);
+                if (victim == null || !AcceptMission(kv.Value.Token, kv.Value.Phase))
+                    continue;
+                try
+                {
+                    kv.Value.State.ApplyTo(victim);
+                    _damageStateApplyCount++;
+                    _deferredStateApplyCount++;
+                }
+                catch (Exception ex)
+                {
+                    _damageStateApplyFailCount++;
+                    MelonLogger.Warning($"[CoopNet] GHC deferred DamageState apply failed: {ex.Message}");
+                }
+                DeferredDamageByVictim.Remove(kv.Key);
+                if (logState)
+                {
+                    MelonLogger.Msg($"[CoopNet] GHC deferred DamageState applied unit={kv.Key} seq={kv.Value.Seq}");
+                }
+            }
+        }
+        if (DeferredUnitByNetId.Count > 0)
+        {
+            foreach (KeyValuePair<uint, DeferredUnitState> kv in DeferredUnitByNetId.ToArray())
+            {
+                Unit? unit = CoopUnitLookup.TryFindByNetId(kv.Key);
+                if (unit == null || !AcceptMission(kv.Value.Token, kv.Value.Phase))
+                    continue;
+                try
+                {
+                    kv.Value.State.ApplyTo(unit);
+                    _unitStateApplyCount++;
+                    _deferredStateApplyCount++;
+                }
+                catch (Exception ex)
+                {
+                    MelonLogger.Warning($"[CoopNet] GHC deferred UnitState apply failed: {ex.Message}");
+                }
+                DeferredUnitByNetId.Remove(kv.Key);
+                if (logState)
+                    MelonLogger.Msg($"[CoopNet] GHC deferred UnitState applied unit={kv.Key} seq={kv.Value.Seq}");
+            }
+        }
+        if (DeferredCrewByNetId.Count > 0)
+        {
+            foreach (KeyValuePair<uint, DeferredCrewState> kv in DeferredCrewByNetId.ToArray())
+            {
+                Unit? unit = CoopUnitLookup.TryFindByNetId(kv.Key);
+                if (unit == null || !AcceptMission(kv.Value.Token, kv.Value.Phase))
+                    continue;
+                try
+                {
+                    kv.Value.State.ApplyTo(unit);
+                    _crewStateApplyCount++;
+                    _deferredStateApplyCount++;
+                }
+                catch (Exception ex)
+                {
+                    MelonLogger.Warning($"[CoopNet] GHC deferred CrewState apply failed: {ex.Message}");
+                }
+                DeferredCrewByNetId.Remove(kv.Key);
+                if (logState)
+                {
+                    MelonLogger.Msg(
+                        $"[CoopNet] GHC deferred CrewState applied unit={kv.Key} seq={kv.Value.Seq}");
+                }
+            }
+        }
+        if (!logHealth)
+            return;
+        int deferredPending = DeferredDamageByVictim.Count + DeferredUnitByNetId.Count + DeferredCrewByNetId.Count;
+        if (deferredPending > 0 && Time.time >= _nextQueuePressureLogTime)
+        {
+            MelonLogger.Warning(
+                $"[CoopNet][Health] deferred-state pending={deferredPending} appliedTotal={_deferredStateApplyCount} identityReady={CoopSessionState.IdentityReady}");
+            _nextQueuePressureLogTime = Time.time + HealthLogCooldownSeconds;
+        }
+    }
