+    {
+        epoch = 0;
+        partIndex = 0;
+        partCount = 0;
+        entries = Array.Empty<(uint, uint, byte)>();
+        if (!IsCoopControl(data, length) || length < WireMapHeaderLength || data[4] != OpWireMapSync)
+            return false;
+        int n = data[5];
+        partIndex = data[6];
+        partCount = data[7];
+        epoch = BitConverter.ToUInt32(data, 8);
+        if (partCount == 0 || partIndex >= partCount || n > MaxWireMapEntriesPerPart)
+            return false;
+        int need = WireMapHeaderLength + n * WireMapEntryLength;
+        if (length < need)
+            return false;
+        var parsed = new (uint, uint, byte)[n];
+        int o = WireMapHeaderLength;
+        for (int i = 0; i < n; i++)
+        {
+            uint hostWireId = BitConverter.ToUInt32(data, o);
+            o += 4;
+            uint spawnKeyHash = BitConverter.ToUInt32(data, o);
+            o += 4;
+            byte ownerPeerId = data[o];
+            o += 4; // owner + flags + pad
+            parsed[i] = (hostWireId, spawnKeyHash, ownerPeerId);
+        }
+        entries = parsed;
+        return true;
+    }
