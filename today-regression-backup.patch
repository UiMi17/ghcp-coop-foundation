+    /// Entry: u32 hostWireId, u32 spawnKeyHash, u8 ownerPeerId, u8 flags, u16 pad.
+    /// </summary>
+    public static int WriteWireMapPart(
+        byte[] buffer,
+        ReadOnlySpan<(uint hostWireId, uint spawnKeyHash, byte ownerPeerId)> entries,
+        byte partIndex,
+        byte partCount,
+        uint epoch)
+    {
+        int n = entries.Length;
+        if (n > MaxWireMapEntriesPerPart)
+            throw new ArgumentException("too many entries for one wire-map part", nameof(entries));
+        int need = WireMapHeaderLength + n * WireMapEntryLength;
+        if (buffer.Length < need)
+            throw new ArgumentException("buffer too small", nameof(buffer));
+        buffer[0] = Magic0;
+        buffer[1] = Magic1;
+        buffer[2] = Magic2;
+        buffer[3] = WireVersion1;
+        buffer[4] = OpWireMapSync;
+        buffer[5] = (byte)n;
+        buffer[6] = partIndex;
+        buffer[7] = partCount;
+        BitConverter.GetBytes(epoch).CopyTo(buffer, 8);
+        int o = WireMapHeaderLength;
+        for (int i = 0; i < n; i++)
+        {
+            BitConverter.GetBytes(entries[i].hostWireId).CopyTo(buffer, o);
+            o += 4;
+            BitConverter.GetBytes(entries[i].spawnKeyHash).CopyTo(buffer, o);
+            o += 4;
+            buffer[o] = entries[i].ownerPeerId;
+            buffer[o + 1] = 0;
+            buffer[o + 2] = 0;
+            buffer[o + 3] = 0;
+            o += 4;
+        }
+        return need;
+    }
